# =============================================================================
# VTMS — environment template (safe to commit)
# =============================================================================
# Copy to .env.local and fill blanks. Import the filled .env.local into Vercel
# (Production + Preview). Never commit real secrets.
#
# Staff credentials flow (custom auth + Resend):
#   Admin invites → email to /welcome?token=... → set password
#   Or Forgot password → /reset-password?token=...
# =============================================================================

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Site (invite/reset links)
PUBLIC_SITE_URL=https://www.scmtvet.com

# Resend
RESEND_API_KEY=
EMAIL_FROM=VTMS <notifications@scmtvet.com>
# FINANCIAL_NOTIFY_FROM=VTMS <notifications@scmtvet.com>

# Local-only bootstrap (do NOT put on Vercel)
# OWNER_BOOTSTRAP_EMAIL=ebrinetushabe@gmail.com
# OWNER_BOOTSTRAP_NAME=System Owner
# OWNER_BOOTSTRAP_PASSWORD=
