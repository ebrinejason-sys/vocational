# =============================================================================
# VTMS environment variables — copy to .env.local, fill in, mirror in Vercel
# =============================================================================
# Local:  copy this file → .env.local  (git-ignored, never commit)
# Vercel: Project → Settings → Environment Variables (Production + Preview)
# After changing VITE_* vars you MUST redeploy on Vercel (baked in at build).
# =============================================================================

# ── Supabase project ─────────────────────────────────────────────────────────
# Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Dashboard → API Keys → Publishable key (sb_publishable_...)
# Used by the browser. Safe with RLS enabled.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_YOUR_KEY_HERE

# Dashboard → API Keys → Secret key (sb_secret_...)
# Server only — invite staff, auth APIs, notifications. NEVER expose to browser.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_KEY_HERE

# Dashboard → JWT Keys → Legacy HS256 (Shared Secret) → Reveal
# NOT the ECC key ID. NOT the publishable/secret API keys.
# Used to sign login tokens for custom auth + RLS.
SUPABASE_JWT_SECRET=your_legacy_hs256_jwt_secret_here

# ── Site URL (custom domain) ─────────────────────────────────────────────────
PUBLIC_SITE_URL=https://www.scmtvet.com

# ── Email (Resend) ───────────────────────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_YOUR_KEY_HERE

# Must be a verified sender domain in Resend
EMAIL_FROM=VTMS <notifications@scmtvet.com>
